# Example Nginx reverse proxy for Novatrix on EC2 (TLS with Certbot).
# Copy to /etc/nginx/sites-available/novatrix and symlink sites-enabled, then:
#   sudo certbot --nginx -d your.domain.com

upstream novatrix_next {
  server 127.0.0.1:3000;
  keepalive 64;
}

server {
  listen 80;
  server_name your.domain.com;

  location / {
    proxy_pass http://novatrix_next;
    proxy_http_version 1.1;
    proxy_set_header Host $host;
    proxy_set_header X-Real-IP $remote_addr;
    proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
    proxy_set_header X-Forwarded-Proto $scheme;
    proxy_read_timeout 3600s;
    proxy_send_timeout 3600s;
    # SSE from Next.js chat
    proxy_buffering off;
    proxy_cache off;
  }
}
