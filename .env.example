# Database
DATABASE_URL="postgresql://novatrix:novatrix@localhost:5432/novatrix?schema=public"

# LLM (OpenAI-compatible: OpenAI, Groq, Azure, local Ollama with openai base URL)
OPENAI_API_KEY=""
OPENAI_BASE_URL="https://api.openai.com/v1"
OPENAI_MODEL="gpt-4o-mini"

# Sandbox: docker | mock (mock = no Docker, local restricted exec for dev)
SANDBOX_MODE="mock"
SANDBOX_IMAGE="novatrix-sandbox:latest"
# Docker network for sandbox containers: none (isolated) or bridge (outbound Internet)
SANDBOX_DOCKER_NETWORK="none"
# Optional absolute path to tools.manifest.yaml
# TOOL_MANIFEST_PATH=

# Optional: require x-api-key header (and browser localStorage MUTATION_API_KEY) for mutating APIs
# MUTATION_API_KEY=

# Allowed URL patterns for http.request tool (comma-separated prefixes), e.g. https://example.com,http://localhost:3000
TARGET_ALLOWLIST="http://localhost,https://localhost,http://127.0.0.1"

# Embeddings (Phase 2 memory)
OPENAI_EMBEDDING_MODEL="text-embedding-3-small"

# Redis for BullMQ worker (optional)
REDIS_URL="redis://localhost:6379"

# Integrations (optional)
# GITHUB_TOKEN=
# GITHUB_REPO=owner/repo
# SLACK_BOT_TOKEN=
# SLACK_CHANNEL_ID=
# JIRA_HOST=
# LINEAR_API_KEY=
