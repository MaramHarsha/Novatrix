# Database

DATABASE_URL="postgresql://novatrix:novatrix@localhost:5432/novatrix?schema=public"

# EC2 / Ubuntu: after `docker compose up -d`, this URL matches docker-compose.yml. Automated install: scripts/ubuntu/setup-ubuntu.sh (see docs/DEPLOY-AWS-EC2.md).



# LLM: anthropic (default) | openai

# Optional: you can leave API keys empty here and set them only in the web UI (sidebar → LLM).

LLM_PROVIDER="anthropic"



# --- OpenAI-compatible (OpenAI, Azure, Groq, LiteLLM, local Ollama, …) ---

# Used when LLM_PROVIDER=openai. Embeddings/memory also use OPENAI_API_KEY when set.

OPENAI_API_KEY=""

# OpenAI: https://api.openai.com/v1  |  Ollama: http://127.0.0.1:11434/v1  |  Groq: https://api.groq.com/openai/v1

OPENAI_BASE_URL="https://api.openai.com/v1"

# Any model id your endpoint accepts, e.g. gpt-4o-mini, gpt-4o, o4-mini, o3, llama3.2 (Ollama), …

OPENAI_MODEL="gpt-4o-mini"



# --- Anthropic Claude (Messages API) ---

# Used when LLM_PROVIDER=anthropic. See https://docs.anthropic.com/en/docs/about-claude/models

ANTHROPIC_API_KEY=""

# Examples: claude-opus-4-7, claude-opus-4-6, claude-sonnet-4-6, claude-sonnet-4-5, claude-haiku-4-5, …

ANTHROPIC_MODEL="claude-opus-4-6"



# --- LLM rate-limit / overload retries (429, 503; Anthropic also 529) ---

# Honors Retry-After / retry-after when the API returns it.

LLM_MAX_RETRIES="6"

LLM_RETRY_BASE_MS="2000"

LLM_RETRY_MAX_MS="90000"



# Sandbox: docker = tools in containers (required for nuclei/httpx/Exegol) | mock = host shell only (no scanners)

SANDBOX_MODE="docker"

SANDBOX_IMAGE="novatrix-sandbox:latest"

# Docker network: bridge = DNS/Internet from containers (needed for most scans and pulls). none = isolated egress.

SANDBOX_DOCKER_NETWORK="bridge"

# Optional: docker run --entrypoint. bash = /bin/bash; none|off = do not override image entrypoint.

# Leave unset for auto (Exegol images get --entrypoint /bin/bash). See docs/EXEGOL.md.

# SANDBOX_DOCKER_ENTRYPOINT=

# Example Exegol (large upstream toolset): pull nwodtuhs/exegol:web then set:

# SANDBOX_IMAGE="nwodtuhs/exegol:web"

# SANDBOX_MODE="docker"

# SANDBOX_DOCKER_NETWORK="bridge"

# Per-session overrides (Novatrix / Exegol images, network) are available in the web UI after `npx prisma db push`.

# Optional absolute path to tools.manifest.yaml

# TOOL_MANIFEST_PATH=



# Optional: require x-api-key header (and browser localStorage MUTATION_API_KEY) for mutating APIs

# MUTATION_API_KEY=



# Allowed URL patterns for http.request tool (comma-separated prefixes), e.g. https://example.com,http://localhost:3000

TARGET_ALLOWLIST="http://localhost,https://localhost,http://127.0.0.1"



# Embeddings (Phase 2 memory) — OpenAI-compatible embeddings API

OPENAI_EMBEDDING_MODEL="text-embedding-3-small"



# Redis for BullMQ worker (optional)

REDIS_URL="redis://localhost:6379"



# Integrations (optional)

# GITHUB_TOKEN=

# GITHUB_REPO=owner/repo

# SLACK_BOT_TOKEN=

# SLACK_CHANNEL_ID=

# JIRA_HOST=

# LINEAR_API_KEY=


